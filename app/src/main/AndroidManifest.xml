<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-feature android:name= "android.hardware.camera.any"/>
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion ="28"/>
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Phasmatic">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.register.RegisterActivity"
            android:exported="false" />
        <activity android:name=".ui.register.RegisterComposeActivity" />

        <activity android:name=".ui.userinfo.UserInfoActivity" />
        <activity android:name=".ui.userinfo.UserInfoComposeActivity" />
        <activity android:name=".ui.modeSelection.ModeSelectionComposeActivity" />
        <activity android:name=".ui.login.LoginActivity" />
        <activity android:name=".ui.login.LoginComposeActivity" />
        <activity android:name=".ui.erasmus.ErasmusChatComposeActivity" />


        <activity
            android:name=".ui.modeSelection.ModeSelectionActivity"
            android:exported="false" />

        <activity android:name=".ui.erasmus.ErasmusChatActivity" />

        <activity android:name=".ui.master.MasterChatActivity" />
        <activity android:name=".ui.master.MasterChatComposeActivity" />

        <activity android:name=".ui.questionnaire.QuestionnaireActivity" />
        <activity android:name=".ui.questionnaire.QuestionnaireComposeActivity"/>

        <activity android:name=".ui.Profile_Menu.account_settings.AccountActivity" />
        <activity android:name=".ui.Profile_Menu.account_settings.AccountComposeActivity" />

        <activity android:name=".ui.Profile_Menu.edit_account_settings.EditProfileActivity" />
        <activity
            android:name=".ui.Profile_Menu.edit_account_settings.EditProfileComposeActivity"/>

        <activity android:name=".ui.Profile_Menu.edit_academic_account_settings.EditUserInfoActivity" />
        <activity android:name=".ui.Profile_Menu.edit_academic_account_settings.EditUserInfoComposeActivity"/>

        <activity android:name=".data.model.FaceGuideOverlay"
            tools:ignore="Instantiatable" />

        <activity android:name=".ui.Forum.forum.ForumActivity" />
        <activity android:name=".ui.Forum.forum.ForumComposeActivity" />

        <activity android:name=".extras.InternetConnection"
            tools:ignore="Instantiatable" />



        <activity android:name=".ui.notes.Notes.NotesActivity"/>
        <activity android:name=".ui.notes.Notes.NotesComposeActivity"
            tools:ignore="MissingClass" />

        <activity android:name=".ui.notes.add_note.AddNoteActivity"
            tools:ignore="Instantiatable" />
        <activity
            android:name=".ui.notes.add_note.AddNoteComposeActivity"
            tools:ignore="MissingClass" />

        <activity android:name=".ui.Forum.new_review.NewReviewActivity" />
        <activity android:name=".ui.Forum.new_review.NewReviewComposeActivity" />

        <activity android:name=".ui.Forum.personal_review.ReviewDetailActivity" />
        <activity android:name=".ui.Forum.personal_review.ReviewDetailComposeActivity" />

        <activity android:name=".ui.forget.ForgetActivity" />
        <activity android:name=".ui.forget.ForgetComposeActivity" />

        <activity android:name=".ui.Profile_Menu.public_profile.PublicProfileActivity" />

        <activity android:name=".ui.Profile_Menu.public_profile.PublicProfileComposeActivity"/>

        <activity android:name=".ui.Chat.users_to_chat.UsersActivity" />
        <activity android:name=".ui.Chat.users_to_chat.UsersComposeActivity" />
        <activity android:name=".ui.Chat.chat.ChatActivity"/>
        <activity android:name=".ui.Chat.chat.ChatComposeActivity"/>

        <activity android:name=".ui.conference.conference_1_N.ConferenceActivity"/>
        <activity android:name=".ui.conference.conference_1_N.ConferenceComposeActivity"/>


        <activity android:name=".ui.conference.general_conference.GeneralConferenceActivity" />
        <activity android:name=".ui.conference.general_conference.GeneralConferenceComposeActivity" />

        <activity android:name=".ui.career.CareerChatActivity" />
        <activity android:name=".ui.career.CareerChatComposeActivity" />

        <service
            android:name=".extras.FCMTokenService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="face" />
    </application>

</manifest>
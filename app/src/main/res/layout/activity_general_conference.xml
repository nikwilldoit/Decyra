<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainConference"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1E3A5F">

    <!-- Back Button -->
    <ImageButton
        android:id="@+id/btnBackConference"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:background="@android:color/transparent"
        android:src="@drawable/baseline_arrow_back_24"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/black" />

    <!-- Profile -->
    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@drawable/profile_circle_bg"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        android:src="@drawable/baseline_face_24"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Notifications -->

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitleConference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start a Video Conference"
        android:textColor="@android:color/black"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnBackConference"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/txtSubtitleConference"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Invite users to your room"
        android:textColor="#CC000000"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitleConference"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/edtSearchUser"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Search user..."
        android:padding="12dp"
        android:background="@drawable/video_frame_bg"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitleConference"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RecyclerView -->

    <!-- Confirm Button -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerUsers"
        android:layout_width="409dp"
        android:layout_height="383dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/video_frame_bg"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnConfirmConference"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitleConference"
        app:layout_constraintVertical_bias="0.955" />

    <Button
        android:id="@+id/btnConfirmConference"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Confirm"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#FF3B82F6"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnJoinRoom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Join Button -->
    <Button
        android:id="@+id/btnJoinRoom"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Join Room"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#FF10B981"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>